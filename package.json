{
  "name": "textlint-rule-preset-ja-aifirst",
  "version": "1.2.0",
  "description": "textlint preset for AI-friendly Japanese writing: AI grep optimization (prh + abbr + period + weak-phrase + identifier-backtick) + JTF style + ja-hiragana rules.",
  "main": "index.js",
  "files": [
    "index.js",
    "prh.yml",
    "rules/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "textlint test/ng/ test/ok/",
    "lint:ok": "textlint test/ok/",
    "lint:dogfood": "textlint README.md docs/RATIONALE.md CHANGELOG.md",
    "fix": "textlint --fix test/",
    "test:ng": "node tools/test-ng.mjs",
    "test:custom": "node tools/test-custom-rules.mjs",
    "test": "npm run lint:ok && npm run test:ng && npm run test:custom && npm run lint:dogfood"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rasshii/textlint-rule-preset-ja-aifirst.git"
  },
  "keywords": [
    "textlintrule",
    "textlint",
    "textlint-rule-preset",
    "japanese",
    "proofreading",
    "prh",
    "jtf-style",
    "ai",
    "llm",
    "claude-code",
    "cursor",
    "ai-coding",
    "ai-grep",
    "agentic",
    "technical-writing"
  ],
  "author": "rasshii",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rasshii/textlint-rule-preset-ja-aifirst/issues"
  },
  "homepage": "https://github.com/rasshii/textlint-rule-preset-ja-aifirst#readme",
  "engines": {
    "node": ">=18.14.0"
  },
  "peerDependencies": {
    "textlint": ">=13.0.0"
  },
  "dependencies": {
    "@textlint/module-interop": "^14.2.0",
    "textlint-filter-rule-comments": "^1.2.2",
    "textlint-rule-abbr-within-parentheses": "^1.0.2",
    "textlint-rule-ja-hiragana-daimeishi": "^1.0.0",
    "textlint-rule-ja-hiragana-fukushi": "^1.3.0",
    "textlint-rule-ja-hiragana-hojodoushi": "^1.1.0",
    "textlint-rule-ja-keishikimeishi": "^1.0.5",
    "textlint-rule-ja-no-abusage": "^3.0.0",
    "textlint-rule-ja-no-mixed-period": "^3.0.2",
    "textlint-rule-ja-no-redundant-expression": "^4.0.1",
    "textlint-rule-ja-no-successive-word": "^2.0.1",
    "textlint-rule-ja-no-weak-phrase": "^2.0.0",
    "textlint-rule-max-kanji-continuous-len": "^1.1.1",
    "textlint-rule-max-ten": "^5.0.0",
    "textlint-rule-no-doubled-joshi": "^5.1.1",
    "textlint-rule-no-dropping-the-ra": "^3.0.0",
    "textlint-rule-no-mix-dearu-desumasu": "^6.0.4",
    "textlint-rule-no-mixed-zenkaku-and-hankaku-alphabet": "^1.0.1",
    "textlint-rule-preset-jtf-style": "^2.3.14",
    "textlint-rule-prh": "^6.1.0",
    "textlint-rule-sentence-length": "^5.2.1"
  },
  "devDependencies": {
    "textlint": "^14.2.0",
    "@textlint/kernel": "^14.2.0",
    "@textlint/textlint-plugin-markdown": "^14.2.0"
  }
}
